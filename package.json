{
  "name": "aws-hosted-podcast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cdk": "cdk",
    "synth": "pnpm build && cdk synth",
    "deploy": "pnpm build && cdk deploy",
    "diff": "pnpm build && cdk diff",
    "bootstrap": "pnpm build && cdk bootstrap",
    "download:podcast": "tsx scripts/download-podcast.ts",
    "download": "pnpm download:podcast"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "aws-cdk": "^2.1127.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
